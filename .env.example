# ---- PostgreSQL ----
POSTGRES_USER=patient_app
POSTGRES_PASSWORD=patient_app
POSTGRES_DB=patient_timeseries
POSTGRES_PORT=5432

# ---- Backend ----
# Used when running the backend directly on the host (npm run dev/start).
# When running the full prod stack via docker-compose.prod.yml, this is
# overridden there to point at the "db" service hostname instead of localhost.
DATABASE_URL=postgresql://patient_app:patient_app@localhost:5432/patient_timeseries?schema=public

MOCK_API_URL=https://mockapi-furw4tenlq-ez.a.run.app/data
DEFAULT_PATIENT_COUNT=10
BACKEND_PORT=4000
CORS_ORIGIN=http://localhost:3000

# ---- Frontend ----
NEXT_PUBLIC_TRPC_URL=http://localhost:4000/trpc
FRONTEND_PORT=3000
