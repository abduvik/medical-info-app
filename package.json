{
  "name": "patient-timeseries",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "nest start --watch",
    "dev:frontend": "next dev frontend -p 3000",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "nest build",
    "build:frontend": "next build frontend",
    "start:backend": "node dist/backend/main.js",
    "start:frontend": "next start frontend -p 3000",
    "start:backend:pm2": "pm2-runtime ecosystem.config.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@trpc/tanstack-react-query": "^11.18.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "pm2": "^7.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
